# Auto detect text files and perform LF normalization
* text=auto

# Source code files
*.cs text diff=csharp
*.csproj text
*.sln text merge=union
*.xml text
*.json text
*.config text

# Documentation
*.md text diff=markdown
*.txt text
*.yml text
*.yaml text

# Git files
*.gitignore text
*.gitattributes text
LICENSE text
README.md text

# Binary files
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary

# NuGet packages
*.nupkg binary
*.snupkg binary

# Build outputs
*.dll binary
*.exe binary
*.pdb binary
*.so binary
*.dylib binary

# Test results
*.trx binary
*.coverage binary
*.cobertura.xml binary

# Archives
*.zip binary
*.tar binary
*.gz binary

# Line endings for specific platforms
*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Force LF for .cs files (recommended for cross-platform)
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf merge=union

# Force CRLF for Windows-specific files
*.ps1 text eol=crlf
*.bat text eol=crlf

# Linguist - GitHub language detection
*.cs linguist-language=C#
*.csproj linguist-language=C#
*.sln linguist-language=C#

# Exclude generated files from GitHub stats
src/test/TestResults/** linguist-generated=true
src/main/obj/** linguist-generated=true
src/test/obj/** linguist-generated=true
artifacts/** linguist-generated=true
